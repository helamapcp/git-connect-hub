{
    "name": "BagTransfer",
    "type": "object",
    "properties": {
        "transfer_number": {
            "type": "string",
            "description": "N\u00famero da transfer\u00eancia (ex: T-00041)"
        },
        "origin_location": {
            "type": "string",
            "enum": [
                "PMP",
                "F\u00c1BRICA"
            ],
            "default": "PMP"
        },
        "destination_location": {
            "type": "string",
            "enum": [
                "PMP",
                "F\u00c1BRICA"
            ],
            "default": "F\u00c1BRICA"
        },
