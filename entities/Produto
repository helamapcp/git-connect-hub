{
    "name": "Produto",
    "type": "object",
    "properties": {
        "codigo": {
            "type": "string",
            "description": "C\u00f3digo \u00fanico do produto"
        },
        "nome": {
            "type": "string",
            "description": "Nome do produto"
        },
        "categoria": {
